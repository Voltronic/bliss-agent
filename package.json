{
  "name": "bliss-agent",
  "version": "1.0.0",
  "description": "Bliss AI Code Agent — Electron + Vue 3 + Qwen3",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "test": "node --test scripts/regressions.test.js",
    "build": "vite build && electron-builder",
    "electron": "electron ."
  },
  "dependencies": {
    "highlight.js": "^11.11.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.2.0",
